            "items": {
                "cancel": {
                    "q": "Can I cancel anytime?",
                    "a": "Yes, absolutely. Your subscription can be canceled at any time, directly in your account settings, with no questions or tricks."
                },
                "devices": {
                    "q": "Is it available for Android and iPhone?",
                    "a": "Yes, Vitaflix is available and optimized on both the App Store (iOS) and Google Play (Android)."
                },
                "support": {
                    "q": "Does the app include personalized monitoring?",
                    "a": "No. Vitaflix is a creative meal organization tool. Our focus is to give you total autonomy and enormous practical sense, not including consultations or chat monitoring."
                },
                "shopping": {
                    "q": "Does the app create an automatic shopping list?",
                    "a": "Yes! Vitaflix automatically generates a shopping list organized by supermarket sections, based on the recipes you choose for your week."
                },
                "diet": {
                    "q": "Are there vegetarian or vegan options?",
                    "a": "Yes, our database includes several vegetarian, vegan, and gluten-free options, allowing you to filter recipes according to your dietary preferences."
                },
                "payments": {
                    "q": "How do payments work?",
                    "a": "Payments are processed securely through the App Store (Apple) or Google Play Store (Android), ensuring full protection of your data."
                }
            }
        },
