{
  "name": "temp_app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:sandbox": "next dev",
    "dev:prod": "npx dotenv-cli -e .env.prod -- next dev",
    "build": "next build",
    "build:sandbox": "npx dotenv-cli -e .env.local -- next build",
    "build:prod": "npx dotenv-cli -e .env.prod -- next build",
    "start": "next start",
    "start:sandbox": "npx dotenv-cli -e .env.local -- next start",
    "start:prod": "npx dotenv-cli -e .env.prod -- next start",
    "lint": "eslint",
    "i18n:audit": "node scripts/audit-translations.mjs",
    "schema:sync:source": "node scripts/sync-source-schema-migrations.mjs",
    "schema:sync:sandbox": "SOURCE_ENV_FILE=.env.local node scripts/sync-source-schema-migrations.mjs",
    "schema:check:sandbox": "CHECK_ONLY=true SOURCE_ENV_FILE=.env.local node scripts/sync-source-schema-migrations.mjs",
    "data:promote": "node scripts/promote-catalog-data.mjs",
    "data:promote:sandbox-to-prod": "SOURCE_ENV_FILE=.env.local TARGET_ENV_FILE=.env SYNC_DIRECTION='sandbox->prod' node scripts/promote-catalog-data.mjs",
    "data:promote:prod-to-sandbox": "SOURCE_ENV_FILE=.env TARGET_ENV_FILE=.env.local SYNC_DIRECTION='prod->sandbox' node scripts/promote-catalog-data.mjs",
    "data:promote:apply:sandbox-to-prod": "DRY_RUN=false SOURCE_ENV_FILE=.env.local TARGET_ENV_FILE=.env SYNC_DIRECTION='sandbox->prod' node scripts/promote-catalog-data.mjs",
    "data:promote:apply:prod-to-sandbox": "DRY_RUN=false SOURCE_ENV_FILE=.env TARGET_ENV_FILE=.env.local SYNC_DIRECTION='prod->sandbox' node scripts/promote-catalog-data.mjs",
    "storage:sync": "node scripts/sync-storage.mjs",
    "storage:sync:sandbox-to-prod": "SOURCE_ENV_FILE=.env.local TARGET_ENV_FILE=.env SYNC_DIRECTION='sandbox->prod' node scripts/sync-storage.mjs",
    "storage:sync:prod-to-sandbox": "SOURCE_ENV_FILE=.env TARGET_ENV_FILE=.env.local SYNC_DIRECTION='prod->sandbox' node scripts/sync-storage.mjs",
    "storage:sync:apply:sandbox-to-prod": "DRY_RUN=false SOURCE_ENV_FILE=.env.local TARGET_ENV_FILE=.env SYNC_DIRECTION='sandbox->prod' node scripts/sync-storage.mjs",
    "storage:sync:apply:prod-to-sandbox": "DRY_RUN=false SOURCE_ENV_FILE=.env TARGET_ENV_FILE=.env.local SYNC_DIRECTION='prod->sandbox' node scripts/sync-storage.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@stripe/stripe-js": "^8.8.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.98.0",
    "@tanstack/react-table": "^8.21.3",
    "@types/uuid": "^10.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "firebase-admin": "^13.7.0",
    "framer-motion": "^12.34.3",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "next-intl": "^4.8.3",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.9",
    "posthog-js": "^1.363.1",
    "posthog-node": "^5.28.5",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-easy-crop": "^5.5.6",
    "react-hook-form": "^7.71.2",
    "recharts": "^2.15.4",
    "resend": "^6.9.3",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "stripe": "^20.4.0",
    "tailwind-merge": "^3.5.0",
    "twilio": "^5.12.2",
    "use-debounce": "^10.1.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
